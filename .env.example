# 複製這份成 .env（已被 .gitignore 排除，不會進版控）。

# Neo4j 連線設定（本地 docker 預設值）
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password123

# LLM / Embedding 設定
# LLM_BASE_URL 留空 = 使用官方 OpenAI endpoint；
# 也可以填任何 OpenAI-compatible 端點，例如 Azure AI Foundry 的 v1 endpoint：
#   https://<your-resource>.services.ai.azure.com/openai/v1/
LLM_BASE_URL=
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
